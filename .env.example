# =============================================
# TM Time Manager - Environment Configuration
# Kopiraj ovaj fajl u .env i popuni vrijednosti
# =============================================

# Server
PORT=3000
NODE_ENV=production

# PostgreSQL baza podataka
DB_HOST=localhost
DB_PORT=5432
DB_NAME=timemanager
DB_USER=tm_user
DB_PASSWORD=PROMIJENI_OVU_LOZINKU_123

# JWT tajni ključ - stavi dugački nasumični string!
JWT_SECRET=PROMIJENI_OVE_SLOVA_U_DUGACKI_RANDOM_STRING_abcdef123456

# Koliko dugo token vrijedi (npr. 8h = radni dan, 7d = tjedan)
JWT_EXPIRES_IN=8h

# Admin nalog koji se kreira pri setup-u
ADMIN_EMAIL=admin@firma.com
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Administrator
